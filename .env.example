NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=
ANTHROPIC_API_KEY=
NODERED_WEBHOOK_SECRET=

# WhatsApp Queue - required for /api/wa/process-queue worker
# Generate with: openssl rand -hex 32
# Must match the Authorization: Bearer header sent by your scheduler
CRON_SECRET=

# WhatsApp Queue - optional tuning (safe to omit, defaults shown)
# WA_QUEUE_BUDGET_MS=55000        # max ms per worker invocation (default 55s)
# WA_QUEUE_BATCH_SIZE=10          # max messages claimed per invocation (default 10)
# WA_QUEUE_RECOVERY_MINUTES=10    # minutes before stuck-processing rows are recovered (default 10)
